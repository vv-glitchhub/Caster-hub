# Caster-hub environment example
# Copy this file to .env.local and fill values when integrations are connected.

# App
NEXT_PUBLIC_APP_NAME=Caster OS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase future cloud sync
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI future shared agent
OPENAI_API_KEY=

# Stripe future billing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Feature flags
NEXT_PUBLIC_ENABLE_LOCAL_STORAGE=true
NEXT_PUBLIC_ENABLE_SUPABASE_SYNC=false
NEXT_PUBLIC_ENABLE_BILLING=false
